    <style>
        :root {
            --bg-side: #0F1A10; 
            --bg-main: #141E15;
            --bg-card: #1C2B1E;
            --ruth-green: #78B32D; 
            --ruth-yellow: #FFD700; 
            --ruth-dark: #050505;
            --amber: #F5A623;
            --red: #FF4D4D;
            --blue: #4D96FF;
            --text-main: #F0F4F0;
            --text-dim: #A0B0A0;
            --border: #2D3D2F;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Be Vietnam Pro', sans-serif;
            background-color: var(--bg-main);
            color: var(--text-main);
            height: 100vh;
            display: flex;
            overflow: hidden;
        }

        /* --- SIDEBAR --- */
        aside {
            width: 280px;
            background: var(--bg-side);
            display: flex;
            flex-direction: column;
            border-right: 1px solid var(--border);
            flex-shrink: 0;
        }
        .sidebar-header {
            padding: 25px 20px;
            text-align: center;
            border-bottom: 1px solid var(--border);
            background: linear-gradient(180deg, rgba(120, 179, 45, 0.1) 0%, transparent 100%);
        }
        .sidebar-header h2 { font-size: 1.1rem; color: var(--ruth-green); letter-spacing: 2px; font-weight: 800; }
        
        .nav-list {
            flex-grow: 1;
            overflow-y: auto;
            padding: 10px 0;
        }
        .nav-item {
            padding: 12px 24px;
            font-size: 0.8rem;
            color: var(--text-dim);
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: 0.3s;
            border-left: 4px solid transparent;
        }
        .nav-item:hover { background: rgba(120, 179, 45, 0.05); color: white; }
        .nav-item.active { 
            background: rgba(120, 179, 45, 0.15); 
            color: var(--ruth-green); 
            border-left-color: var(--ruth-green);
            font-weight: 700;
        }
        .nav-item.special { color: var(--ruth-yellow); border-left-color: var(--ruth-yellow); background: rgba(255, 215, 0, 0.05); }

        /* --- MAIN CONTENT --- */
        main {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            padding: 25px;
            overflow-y: auto;
            background: radial-gradient(circle at top right, rgba(120, 179, 45, 0.05), transparent);
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        .dept-title { font-size: 1.6rem; font-weight: 800; border-bottom: 3px solid var(--ruth-green); padding-bottom: 5px; }
        .sync-status { font-size: 0.7rem; color: var(--ruth-green); background: rgba(120, 179, 45, 0.1); padding: 6px 15px; border-radius: 20px; border: 1px solid var(--ruth-green); }

        /* KPI GRID */
        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
            margin-bottom: 20px;
        }
        .kpi-card {
            background: var(--bg-card);
            padding: 20px;
            border-radius: 12px;
            border: 1px solid var(--border);
            transition: 0.3s;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }
        .kpi-card:hover { transform: translateY(-3px); border-color: var(--ruth-green); }
        .kpi-label { font-size: 0.65rem; color: var(--text-dim); text-transform: uppercase; margin-bottom: 8px; letter-spacing: 0.5px; }
        .kpi-value { font-size: 1.6rem; font-weight: 800; color: var(--ruth-green); }
        .kpi-sub { font-size: 0.7rem; margin-top: 6px; }

        /* DATA SECTION */
        .data-section {
            display: grid;
            grid-template-columns: 1.4fr 1.2fr;
            gap: 20px;
            margin-bottom: 20px;
        }
        .panel {
            background: var(--bg-card);
            border-radius: 12px;
            padding: 20px;
            border: 1px solid var(--border);
        }
        .panel-h { font-size: 0.95rem; font-weight: 700; margin-bottom: 20px; display: flex; justify-content: space-between; color: var(--ruth-yellow); }

        table { width: 100%; border-collapse: collapse; font-size: 0.8rem; }
        th { text-align: left; padding: 12px; color: var(--text-dim); border-bottom: 2px solid var(--border); font-weight: 600; text-transform: uppercase; font-size: 0.7rem; }
        td { padding: 12px; border-bottom: 1px solid var(--border); color: #E0E0E0; }
        tr:hover { background: rgba(255,255,255,0.02); }

        .perf-green { color: var(--ruth-green); font-weight: 700; }
        .perf-amber { color: var(--amber); font-weight: 700; }
        .perf-red { color: var(--red); font-weight: 700; }

        /* BASE BOX */
        .base-box {
            margin-top: auto;
            padding: 15px;
            background: linear-gradient(90deg, rgba(77, 150, 255, 0.1), transparent);
            border: 1px solid rgba(77, 150, 255, 0.3);
            border-radius: 10px;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .base-logo { background: var(--blue); color: white; width: 35px; height: 35px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 1.1rem; flex-shrink: 0; }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 10px; }
    </style>
</head>
