                chartData: { labels: ['T12', 'T1', 'T2', 'T3', 'T4'], datasets: [{ label: 'Doanh thu', data: [20, 22, 21, 25, 23], backgroundColor: '#78B32D' }, { label: 'Chi phí', data: [16, 17, 18, 19, 18], backgroundColor: '#FF4D4D' }] }
            }
        };

        let currentChart = null;

        function showDept(deptId) {
            const dept = departments[deptId];
            
            document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
            const activeNav = Array.from(document.querySelectorAll('.nav-item')).find(el => {
                const searchStr = deptId === 'bod' ? "BAN LÃNH ĐẠO" : dept.title.substring(10, 18);
                return el.textContent.toUpperCase().includes(searchStr.toUpperCase());
            });
            if(activeNav) activeNav.classList.add('active');

            const html = `
                <header>
                    <div class="dept-title">${dept.title}</div>
                    <div class="sync-status">Đồng bộ Base KPI — Update: 06/04/2026 — 00:05</div>
                </header>

                <div class="kpi-grid">
                    ${dept.kpis.map(kpi => `
                        <div class="kpi-card">
                            <div class="kpi-label">${kpi.label}</div>
                            <div class="kpi-value" style="color: var(--ruth-${kpi.color})">${kpi.val}</div>
                            <div class="kpi-sub" style="color: var(--text-dim)">${kpi.sub}</div>
                        </div>
                    `).join('')}
                </div>

                <div class="data-section">
                    <div class="panel">
                        <div class="panel-h">${deptId === 'bod' ? 'THEO DÕI KPI 12 PHÒNG BAN' : 'GHI NHẬN KPI THEO NHÂN SỰ'}</div>
                        <table>
                            <thead>
                                <tr>${dept.tableH.map(h => `<th>${h}</th>`).join('')}</tr>
                            </thead>
                            <tbody>
                                ${dept.tableData.map(row => `
                                    <tr>${row.map(cell => `<td>${cell}</td>`).join('')}</tr>
                                `).join('')}
                            </tbody>
                        </table>
                    </div>
                    <div class="panel">
                        <div class="panel-h">${dept.chartLabel.toUpperCase()}</div>
                        <div style="height: 250px;">
                            <canvas id="deptChart"></canvas>
                        </div>
                    </div>
                </div>

                <div class="base-box">
                    <div class="base-logo">B</div>
                    <div style="font-size: 0.7rem; color: var(--blue);">
                        <strong>BASE KPI ENGINE:</strong> 
                        ${deptId === 'bod' 
                            ? 'Lãnh đạo có cái nhìn tổng quan về hiệu suất toàn công ty. Các phòng ban màu Đỏ cần tập trung cải thiện quy trình vận hành.' 
                            : 'Số liệu được ghi nhận trực tiếp từ quá trình làm việc của từng nhân sự, đảm bảo tính công bằng và động lực phát triển.'}
                    </div>
                </div>
            `;

            document.getElementById('main-content').innerHTML = html;
            renderChart(dept.chartType, dept.chartData);
        }

        function renderChart(type, data) {
            if (currentChart) currentChart.destroy();
            const ctx = document.getElementById('deptChart').getContext('2d');
            
            const options = {
                maintainAspectRatio: false,
                plugins: { 
                    legend: { 
                        display: (type === 'pie' || type === 'doughnut' || type === 'radar'),
                        position: 'bottom',
                        labels: { boxWidth: 10, font: { size: 10 }, color: '#A0B0A0' }
                    } 
                },
                scales: (type === 'pie' || type === 'doughnut' || type === 'radar') ? {} : {
                    y: { grid: { color: '#2D3D2F' }, ticks: { color: '#A0B0A0', font: { size: 9 } } },
                    x: { grid: { display: false }, ticks: { color: '#A0B0A0', font: { size: 9 } } }
                }
            };

            if(type === 'radar') {
                options.scales = {
                    r: {
                        grid: { color: '#2D3D2F' },
                        angleLines: { color: '#2D3D2F' },
                        pointLabels: { color: '#A0B0A0', font: { size: 10 } },
                        ticks: { display: false }
                    }
                };
            }

            currentChart = new Chart(ctx, {
                type: type,
                data: data,
                options: options
            });
        }

        window.onload = () => showDept('bod');

    </script>
</body>
